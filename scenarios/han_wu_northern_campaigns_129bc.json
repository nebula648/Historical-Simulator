  "factions": {
    "han_empire": {
      "name": "大汉帝国",
      "color": "#CC0000",
      "ruler": "刘彻",
      "ruler_title": "皇帝",
      "government": "中央集权帝国",
      "capital": "xi_an",
      "description": "汉兴七十余年，至武帝而极盛。罢黜百家、独尊儒术，盐铁官营、均输平准，帝国的神经已深入每一寸肌理。但年年给匈奴的和亲纳贡是悬在大汉头顶的耻辱——每年数十万钱帛、公主远嫁漠北。现在，刘彻决心终结这一切。",
      "flag_badass": false,
      "culture_buffs": {
        "name": "大汉天威",
        "description": "骑兵征募成本-30%，步兵维持费-20%。帝国后勤体系完善，粮草转运效率翻倍。但连年战争将逐步拖累民心，每连续战争12回合，stability-5。",
