  "factions": {
    "cao_wei": {
      "name": "魏·曹操",
      "color": "#1A3A5C",
      "ruler": "曹操",
      "ruler_title": "汉丞相·魏王",
      "government": "中央集权帝国",
      "capital": "luo_yang",
      "description": "挟天子以令诸侯，曹操已据有天下九州之六。麾下谋士如云（荀彧、荀攸、贾诩、程昱），猛将如雨（夏侯惇、张辽、徐晃、许褚）。官渡一战灭袁绍，北征乌桓定朔方。如今亲率二十三万大军水陆南征，志在一统天下。天下三分，已有二分半在他手中。",
      "flag_badass": true,
      "culture_buffs": {
        "name": "挟天子以令诸侯",
        "description": "威望基础值+30，征募降兵转化率+50%。占据朝廷正统，可发布'天子诏令'强制其他诸侯停战或出兵。但占领区民心基础值-15——名为汉相，实为汉贼的形象已深入人心。",
        "effects": {
          "base_prestige_bonus": 30,
          "surrender_conversion_rate": 50,
          "occupied_stability_penalty": -15
        }
      }
    },
    "sun_wu": {
      "name": "吴·孙权",
      "color": "#8B0000",
      "ruler": "孙权",
      "ruler_title": "讨虏将军·领会稽太守",
      "government": "封建王国",
      "capital": "nanjing",
      "description": "孙策临终遗言：'内事不决问张昭，外事不决问周瑜。'十九岁的孙权继承父兄基业，坐断东南。江东已历三世，国险而民附，长江天堑是天然屏障。水师之精锐冠绝天下——周瑜、程普、黄盖、甘宁，一个个名字就是一场场海战的胜利。但曹操的八十万大军已在江北扎营。",
      "flag_badass": false,
      "culture_buffs": {
        "name": "江东水师",
        "description": "水师战斗力+40%，水战攻防+30%。长江天堑——北方军队渡江时损耗翻倍。但骑兵征募成本+50%——江东缺马。",
        "effects": {
          "navy_combat_bonus": 40,
          "naval_battle_bonus": 30,
          "enemy_river_crossing_attrition_double": true,
          "cavalry_recruit_cost_penalty": 50
        }
      }
    },
    "liu_shu": {
      "name": "汉·刘备",
      "color": "#CC6600",
      "ruler": "刘备",
      "ruler_title": "汉左将军·宜城亭侯·豫州牧",
      "government": "起义政权",
      "capital": "gui_yang",
      "description": "织席贩履的汉室宗亲，颠沛流离半生而无尺寸之地。三顾茅庐请出了卧龙诸葛亮，隆中对的蓝图刚刚展开——先取荆州为家，再图益州为基，待天下有变，两路北伐中原。然而眼下，你带着十万跟随的百姓，每天只能走十几里路。身后是曹操的精锐虎豹骑，前方是茫茫江水。但你的身边站着关羽、张飞、赵云、诸葛亮——天团已聚，只待天时。",
      "flag_badass": false,
      "culture_buffs": {
        "name": "仁义之师",
        "description": "每控制一个新区域，民心自动+10（仁德之名远播）。将领忠诚度固定100（永不叛变）。但国库收入-20%——刘备从不劫掠百姓。",
        "effects": {
          "new_region_stability_bonus": 10,
          "general_loyalty_locked": 100,
          "treasury_income_penalty": -20
        }
      }
    },
    "liu_zhang": {
      "name": "益州·刘璋",
      "color": "#556B2F",
      "ruler": "刘璋",
      "ruler_title": "益州牧",
      "government": "封建王国",
      "capital": "cheng_du",
      "description": "天府之国的守财奴。刘璋暗弱无能、不善用人，但益州富甲天下——都江堰灌溉千里沃野，蜀锦远销万里。张鲁据汉中作乱，刘璋无力征讨，内部暗流涌动。法正、张松已密谋'引狼入室'。没有人知道，这个懦弱的益州牧，正静待一个被称为'皇叔'的人来接管他的江山。",
      "flag_badass": false,
      "culture_buffs": {
        "name": "天府之国",
        "description": "粮草产量+50%，国库收入+20%。但军队士气基础-20——刘璋无将帅之才。",
        "effects": {
          "food_production_bonus": 50,
          "treasury_income_bonus": 20,
          "base_morale_penalty": -20
        }
      }
    },
    "ma_teng": {
      "name": "西凉·马腾",
      "color": "#A0522D",
      "ruler": "马腾",
      "ruler_title": "征西将军",
      "government": "军阀割据",
      "capital": "lan_zhou",
      "description": "西凉铁骑闻名天下，马腾与韩遂割据凉州，虽名义上归顺朝廷，实则独立半独立。其子马超勇冠三军，被羌人尊为'神威天将军'。曹操对这支悬在头顶的西凉铁骑始终心存忌惮——赤壁之战前，他先要确保侧后无忧。",
      "flag_badass": false,
      "culture_buffs": {
        "name": "西凉铁骑",
        "description": "骑兵攻击力+30%，骑兵士气+25。西凉马匹天下第一，征募骑兵成本-40%。但步兵战力-20%。",
        "effects": {
          "cavalry_attack_bonus": 30,
          "cavalry_morale_bonus": 25,
          "cavalry_recruit_cost_reduction": 40,
          "infantry_power_penalty": -20
        }
      }
    },
    "nanman_tribe": {
      "name": "南中诸部",
      "color": "#6B3A2E",
      "ruler": "孟获",
      "ruler_title": "南中渠帅",
      "government": "部落联盟",
      "capital": "yun_nan",
      "description": "南中地区的蛮族部落联盟，以孟获为首。部落据有瘴气密林与险峻山地，善用毒箭与象兵。名义上臣服于益州，实则时有叛乱。南中各部并非铁板一块——孟获只是其中最大的渠帅。",
      "flag_badass": false,
      "culture_buffs": {
        "name": "丛林之鬼",
        "description": "山地/丛林攻防+50%，入侵者在该区域每回合损耗8%兵力。象兵对骑兵有震慑（士气-15）。但水战全军溃败。",
        "effects": {
          "jungle_combat_bonus": 50,
          "invader_attrition_per_turn": 8,
          "elephant_cavalry_morale_debuff": -15,
          "naval_combat_penalty_high": true
        }
      }
    },
    "shanyue_tribe": {
      "name": "山越",
      "color": "#3E6B3A",
      "ruler": "",
      "ruler_title": "山越首领",
      "government": "部落联盟",
      "capital": "",
      "description": "散居在江东山区与南方岛屿的山越部族，常趁江东空虚时出山劫掠。孙权为山越问题头疼已久——这些深山中的部落是江东后方永远的不稳定因素。",
      "flag_badass": false,
