  "factions": {
    "roman_republic": {
      "name": "罗马共和国（SPQR）",
      "color": "#C41E3A",
      "ruler": "元老院与执政官",
      "ruler_title": "Consul（执政官）",
      "government": "贵族共和制·元老院主导",
      "capital": "italia",
      "description": "自推翻王政以来，罗马人以元老院和公民大会统治共和国已有两百余年。刚刚结束的皮洛士战争证明了罗马军团可以击败希腊化王国的战象。现在整个意大利半岛统一在SPQR的旗帜下——但元老们深知，海外的迦太基才是真正的考验。",
      "flag_badass": true,
      "faction_type": "Republic"
    },
    "carthage": {
      "name": "迦太基",
      "color": "#8B4513",
      "ruler": "哈米尔卡·巴卡",
      "ruler_title": "Shophet（苏菲特·执政官）",
      "government": "商业寡头制·百人会议",
      "capital": "carthago",
      "description": "腓尼基人在北非建立的商业帝国，控制着西地中海的贸易路线。迦太基海军拥有三百余艘五列桨战船，是古代世界最强大的海上力量。其雇佣军来自努米底亚骑兵、巴利阿里投石手和西班牙步兵——黄金可以买到一切，除了忠诚。",
      "flag_badass": true,
      "faction_type": "Empire"
    },
    "macedon": {
      "name": "马其顿（安提柯王朝）",
      "color": "#4A6B8A",
      "ruler": "安提柯二世·戈纳塔斯",
      "ruler_title": "Basileus（马其顿国王）",
      "government": "希腊化王国",
      "capital": "macedonia",
      "description": "亚历山大大帝的继承人之一，安提柯王朝统治着马其顿本土和希腊诸城邦。与埃及托勒密、塞琉古帝国三足鼎立，常年争战。对西方的罗马和迦太基，马其顿尚不了解——但这不代表他们不会介入。",
      "flag_badass": false,
      "faction_type": "Kingdom"
    },
    "seleucid_empire": {
      "name": "塞琉古帝国",
      "color": "#B8860B",
      "ruler": "安条克二世·忒奥斯",
      "ruler_title": "Basileus Megas（万王之王）",
      "government": "希腊化帝国·东方专制",
      "capital": "syria",
      "description": "亚历山大大帝遗产中最大的继承者，疆域从爱琴海延伸到印度河。然而帝国过大难治，内部叛乱不断，帕提亚和巴克特里亚正在东方蠢蠢欲动。安条克二世忙于与埃及争霸，无暇西顾。",
      "flag_badass": false,
      "faction_type": "Empire"
    },
    "ptolemaic_egypt": {
