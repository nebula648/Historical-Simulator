  "scripted_events": [
    {
      "id": "nap_austerlitz",
      "name": "奥斯特里茨三皇会战",
      "type": "audience",
      "trigger": {
        "condition": "turn_number <= 3",
        "priority": "mandatory"
      },
      "title": "奥斯特里茨——三皇对决的早晨",
      "narrative": "1805年12月2日。奥斯特里茨村以西的普拉岑高地笼罩在晨雾之中。拿破仑故意示弱，将右翼苏尔特军团后撤，引诱俄奥联军离开高地。达武元帅的第三军团正从维也纳方向强行军赶来。\n\n沙皇亚历山大一世与奥皇弗朗茨二世亲临战场，联军参谋总长魏罗特尔制定了正面强攻法军右翼的计划——而这正中拿破仑的下怀。\n\n日出时分，拿破仑对贝尔蒂埃说：'太阳出来了——这就是奥斯特里茨的太阳！'",
      "choices": [
        {
          "id": "austerlitz_classic",
          "text": "按计划执行：苏尔特突击普拉岑高地，分割联军中央",
          "effects": {
            "treasury": -15000,
            "manpower": -6000,
            "prestige": 40,
            "stability": 15
          },
          "territory_changes": [
            {"region_id": "austria", "to_faction": "french_empire", "reason": "奥斯特里茨大捷，奥地利被迫签订《普雷斯堡和约》"}
          ],
          "narrative_result": "上午9时，苏尔特军团从雾中冲出，直取普拉岑高地——联军中央被一举突破！俄军左翼被压缩至冰封的池塘上，法军炮兵轰击冰面，数千俄军坠入冰水之中。\n\n'最辉煌的胜利！'拿破仑在战报中写道。俄奥联军损失三万六千人，而法军仅损失八千。沙皇亚历山大一世含泪撤退，弗朗茨二世被迫求和。第三次反法同盟土崩瓦解。\n\n欧洲跪倒在这位三十六岁科西嘉人的脚下。"
        },
        {
          "id": "austerlitz_cautious",
          "text": "稳守反击：等待达武军团会合后再发起总攻",
          "effects": {
            "treasury": -8000,
            "manpower": -3000,
            "prestige": 15,
            "stability": 5
          },
          "narrative_result": "拿破仑选择了更保守的战术——等待达武军团完全抵达后才发起攻击。虽然伤亡更小，但联军也得以有序撤退。俄军主力未受重创，沙皇亚历山大发誓要卷土重来。\n\n一场决定性胜利变成了战术性胜利——反法同盟的瓦解可能要再等一年。"
        }
      ]
    },
    {
      "id": "nap_confederation_rhine",
      "name": "莱茵邦联成立",
      "type": "outcome",
      "trigger": {
        "condition": "turn_number >= 6 AND french_empire.controls('austria') == true",
        "priority": "high"
      },
      "title": "神圣罗马帝国的终结——莱茵邦联诞生",
      "narrative": "奥斯特里茨的胜利彻底改变了德意志的政治版图。1806年7月，十六个德意志邦国在巴黎签订条约，宣布脱离神圣罗马帝国，成立莱茵邦联，以拿破仑为保护者。\n\n弗朗茨二世被迫放弃神圣罗马帝国皇帝头衔——这个存在了844年（自奥托大帝962年加冕）的古老帝国正式灭亡。\n\n拿破仑在巴黎得意地宣布：'查理曼的帝国在我的手中复活了。'",
      "auto_effects": {
        "prestige": 25,
        "stability": 10
      },
      "territory_changes": [
        {"region_id": "confederation_rhine", "to_faction": "french_empire", "reason": "莱茵邦联成立，十六个德意志邦国加入法国势力范围"}
      ]
    },
    {
      "id": "nap_prussia_decision",
      "name": "普鲁士的最后通牒",
      "type": "audience",
      "trigger": {
        "condition": "turn_number >= 8 AND french_empire.controls('confederation_rhine') == true",
        "priority": "high"
      },
      "title": "柏林的最后通牒——普鲁士走向战争",
      "narrative": "莱茵邦联的成立触动了普鲁士的神经。腓特烈·威廉三世在俄国的怂恿和王后路易丝的主战情绪推动下，向法国发出最后通牒：法军必须在两周内撤出德意志所有领土。\n\n拿破仑在大本营读到通牒后大笑：'普鲁士人以为他们是腓特烈大帝时代的军队吗？他们还在用三十年前的战术，而我每场战役都在创新。'\n\n但塔列朗警告：'陛下，普鲁士军队仍保留着腓特烈大帝的荣光。小觑他们可能付出代价。'",
      "choices": [
        {
          "id": "defeat_prussia",
          "text": "先发制人！令大军团立即向普鲁士进军",
          "effects": {
            "treasury": -30000,
            "manpower": -10000,
            "prestige": 30,
            "stability": 10
