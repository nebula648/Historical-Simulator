  "factions": {
    "french_empire": {
      "name": "法兰西帝国",
      "color": "#1A3A8A",
      "ruler": "拿破仑·波拿巴",
      "ruler_title": "法兰西人的皇帝",
      "government": "军事独裁·帝国制",
      "capital": "france",
      "description": "从土伦的年轻炮兵上尉到法兰西皇帝，拿破仑仅用了十一年。大军团（Grande Armée）是欧洲最精锐的战争机器，达武、缪拉、内伊、苏尔特等元帅俱为当世名将。然而法国海军在特拉法加遭受重创，英国仍牢牢控制着海洋——拿破仑必须在陆地决战中粉碎反法同盟。",
      "flag_badass": true,
      "faction_type": "Empire"
    },
    "britain": {
      "name": "大不列颠及爱尔兰联合王国",
      "color": "#CC0000",
      "ruler": "乔治三世",
      "ruler_title": "大不列颠国王",
      "government": "君主立宪·议会制",
      "capital": "britain",
      "description": "英国是反法同盟的财政支柱。小皮特首相以每年数百万英镑的补助金维系着大陆上的反法同盟。皇家海军在纳尔逊的率领下控制着英吉利海峡和世界所有重要航道。只要英国不被击败，法国的欧洲霸权就永远不会稳固。",
      "flag_badass": true,
      "faction_type": "Empire"
    },
    "austria": {
      "name": "奥地利帝国",
      "color": "#FFFFFF",
      "ruler": "弗朗茨二世",
      "ruler_title": "奥地利皇帝",
      "government": "绝对君主制",
      "capital": "austria",
      "description": "哈布斯堡王朝的古老帝国是反法同盟的中坚力量。虽然屡败于拿破仑，但奥地利仍是中欧最强大的军事力量之一。弗朗茨二世将女儿玛丽·路易丝嫁给了拿破仑——但这桩政治婚姻并未换来永久的和平。维也纳既是拿破仑最顽强的对手，也是他的姻亲。",
      "flag_badass": false,
      "faction_type": "Empire"
    },
    "russia": {
      "name": "俄罗斯帝国",
      "color": "#006400",
      "ruler": "亚历山大一世",
      "ruler_title": "全俄罗斯的皇帝与独裁者",
      "government": "绝对君主制·农奴制",
      "capital": "russia",
      "description": "年轻的沙皇亚历山大一世自视为欧洲旧秩序的捍卫者。俄罗斯拥有无穷的人力资源和广阔的战略纵深，拿破仑的'大军团'如果深入俄罗斯腹地，将面对的是一个吞噬军队的无底深渊。然而目前，俄奥联军必须在奥斯特里茨阻止拿破仑的锋芒。",
      "flag_badass": false,
      "faction_type": "Empire"
    },
    "prussia": {
      "name": "普鲁士王国",
      "color": "#2E5090",
      "ruler": "腓特烈·威廉三世",
      "ruler_title": "普鲁士国王",
      "government": "绝对君主制·军国传统",
      "capital": "prussia",
      "description": "腓特烈大帝留给普鲁士的遗产——一支训练有素的军队和一个高效的官僚机器——正处在观望状态。柏林的态度暧昧：既不满拿破仑在德意志的扩张，又不愿冒险单独挑战法国。汉诺威被法军占领的事实激怒了普鲁士军官团，但国王本人还在犹豫。",
      "flag_badass": false,
      "faction_type": "Kingdom"
    },
    "spain": {
      "name": "西班牙王国",
      "color": "#FFD700",
      "ruler": "卡洛斯四世",
      "ruler_title": "西班牙国王",
      "government": "绝对君主制（波旁王朝·法国盟友）",
      "capital": "spain",
      "description": "自1796年圣伊尔德丰索条约以来，西班牙被迫成为法国的盟友。西班牙舰队在特拉法加与法国联合出击，几乎全军覆没。卡洛斯四世懦弱无能，实权操于王后宠臣戈多伊之手。西班牙民间对法国的怨恨正在暗中积聚。",
      "flag_badass": false,
      "faction_type": "Kingdom"
    }
