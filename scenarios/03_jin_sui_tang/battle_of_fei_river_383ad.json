  "scripted_events": [
    {
      "id": "fei_river_crossing",
      "name": "淝水对峙",
      "type": "conditional",
      "trigger": {
        "condition": "turn_number >= 1 AND turn_number <= 6",
        "priority": "high"
      },
      "title": "淝水对峙 —— 苻坚百万大军压境",
      "narrative": "前秦前锋已攻陷寿阳，苻坚亲率中军抵达淝水西岸。百万大军列阵，旌旗蔽日，鼓声震天。东晋北府兵八万已推进至淝水东岸，两军隔河对峙。苻坚遣降将朱序前来劝降，朱序却私下告知谢玄：'秦军虽众，然多系胁迫而来，若趁其半渡而击，必溃。'\n\n淝水宽阔而浅，可涉水而过。谢玄面临抉择——是主动出击先发制人，还是坚守东岸以待援军？",
      "choices": [
        {
          "id": "initiative_attack",
          "text": "遣使告诉苻坚：请秦军稍退，让晋军渡河决战（诱敌后撤，半渡而击）",
          "effects": {
            "treasury": -5000,
            "manpower": -5000,
            "prestige": 25,
            "corruption": 2
          },
          "territory_changes": [
            {"region_id": "安徽", "to_faction": "eastern_jin", "reason": "淝水大捷，收复寿阳"}
          ],
          "narrative_result": "谢玄遣使至秦营，言：'君悬军深入，而置阵逼水，此持久之计，岂欲战者乎？若移阵少却，使晋兵得渡，以决胜负，不亦善乎！'苻坚力排众议，下令全军后撤。\n\n然而百万大军语言不通、号令不齐，后撤瞬间变为溃退。朱序趁乱在秦军后方大呼'秦军败了！'，全军大乱。谢玄、刘牢之率八千北府精骑趁势渡河，直冲秦军中军。苻融战马被绊倒，死于乱军之中。苻坚身中流矢，单骑北逃。\n\n北府兵一日内斩首数万、俘获十余万，淝水之战以晋军完胜告终！"
        },
        {
          "id": "defend_river",
          "text": "坚守淝水东岸，利用地利消耗秦军锐气（稳妥防御）",
          "effects": {
            "treasury": -2000,
            "manpower": -1000,
            "stability": 10,
            "prestige": 5,
            "corruption": -1
          },
          "narrative_result": "谢玄下令沿淝水东岸修筑壁垒，以强弩劲弓封锁河面。秦军数度试探渡河，均被北府兵射退。随着冬季临近，秦军粮道延伸数百里，补给日益困难。各族将领牢骚满腹，慕容垂、姚苌等人阳奉阴违，苻坚被迫分兵就粮，百万大军不战自溃……"
        },
        {
          "id": "diplomatic_stall",
          "text": "遣使求和，以金银布帛换取苻坚退兵（外交绥靖）",
          "effects": {
            "treasury": -25000,
            "prestige": -15,
            "stability": 5,
            "corruption": 5
          },
          "narrative_result": "谢安遣使携重金至秦营，卑辞求和。苻坚大喜，以为晋廷怯懦，遂暂缓攻势，与晋使周旋。此举为东晋赢得了宝贵的喘息之机，但朝野上下皆以此为耻，清议哗然，谢氏的执政声望受到动摇……"
        }
      ]
    },
    {
      "id": "murong_changs_coup",
      "name": "慕容垂自立",
      "type": "conditional",
      "trigger": {
        "condition": "turn_number >= 4 AND former_qin.stability <= 30",
        "priority": "high"
      },
      "title": "鲜卑复国 —— 慕容垂趁乱自立",
      "narrative": "淝水之战后，前秦元气大伤，各族降将蠢蠢欲动。慕容垂借口回邺城整顿旧部，脱离苻坚控制。他一到邺城，立即举起复国大旗，自称燕王，重建燕国（后燕）。河北大地数月间尽归慕容氏。\n\n前秦帝国正在崩塌，而东晋朝中，谢安谏言：此乃千载难逢的北伐良机——是否趁机收复中原？",
      "choices": [
        {
          "id": "northern_expedition",
          "text": "出师北伐！令谢玄率北府兵趁势收复洛阳、长安",
          "effects": {
            "treasury": -10000,
            "manpower": -8000,
            "prestige": 30,
            "stability": 15
          },
          "territory_changes": [
            {"region_id": "河南", "to_faction": "eastern_jin", "reason": "北伐收复洛阳"},
            {"region_id": "山东", "to_faction": "eastern_jin", "reason": "北府兵北进收复青州"}
          ],
          "narrative_result": "谢玄率北府兵渡淮北上，势如破竹。洛阳守军开城迎降，关中豪杰亦纷纷起兵响应。晋军前锋直抵长安城外，距收复两京仅一步之遥！然而补给线过长、后方门阀掣肘、桓氏荆州势力不愿配合……北伐能走多远，考验着建康朝廷的意志。"
        },
        {
          "id": "consolidate_south",
          "text": "稳固江南，暂不北顾（休养生息，巩固边防）",
          "effects": {
            "treasury": 5000,
            "manpower": 5000,
            "stability": 10,
            "prestige": -10,
            "food": 500
          },
          "narrative_result": "谢安力排众议，选择暂不出兵。'北伐事大，不可急图。'朝廷全力巩固江淮防线，吸收北方流民充实户籍，休养生息。此举稳妥，但亦有老将感叹：'此乃遗恨千古之良机也……'"
        }
      ]
    },
    {
      "id": "xie_an_dies",
      "name": "谢安薨逝",
      "type": "outcome",
      "trigger": {
        "condition": "turn_number >= 12",
        "priority": "medium"
      },
      "title": "东山再起之人，终于归隐东山",
      "narrative": "太傅、中书监谢安病重薨逝，终年六十六岁。自淝水之战以来，他以一人之力平衡朝中门阀、安抚江北流民、维系北伐大局。他的离去，意味着东晋朝廷失去了最后一位能统合各方的主心骨。\n\n建康台城内外，一片哀恸。乌衣巷中，谢氏子弟披麻戴孝。但更多人心中暗想：没有了谢安，这个朝廷还能走多远？",
      "auto_effects": {
        "stability": -20,
        "prestige": -10,
        "corruption": 15
      }
    },
    {
      "id": "huan_xuan_ambition",
      "name": "桓玄觊觎",
      "type": "conditional",
      "trigger": {
        "condition": "turn_number >= 18 AND eastern_jin.stability <= 40",
        "priority": "high"
      },
      "title": "桓玄问鼎 —— 荆州将叛",
      "narrative": "荆州刺史桓玄（桓温之子）坐镇江陵，手握西府重兵，见朝廷暗弱，渐生不臣之心。他上表要求加九锡、假节钺，名为尊崇，实为试探建康底线。\n\n朝中分为两派：或主张安抚桓玄，以荆州阻隔上游威胁；或主张先下手为强，削其兵权。",
      "choices": [
        {
          "id": "appease_huan",
          "text": "加封桓玄为楚王，以满足其野心绥靖之",
          "effects": {
            "prestige": -20,
            "stability": -5,
            "corruption": 10
          },
          "territory_changes": [
            {"region_id": "湖北", "to_faction": "huan_chu", "reason": "桓玄受封楚王，荆州半独立"}
          ],
          "narrative_result": "朝廷下诏加桓玄为楚王、都督荆雍梁益四州诸军事。桓玄表面上谢恩，实则尽收荆州军政大权。江陵与建康，已成二日并悬之势……"
        },
        {
          "id": "suppress_huan",
          "text": "诏令刘牢之率北府兵讨伐桓玄（武力削藩）",
          "effects": {
            "treasury": -15000,
            "manpower": -12000,
            "stability": -10,
            "prestige": 15
          },
          "narrative_result": "刘牢之奉诏率北府兵西征。桓玄据江陵坚城以守，两军在荆州相持。建康朝中，琅琊王氏暗中与桓玄通款，前线粮草时断时续……这是考验北府兵忠诚与朝堂权术的时刻。"
        }
      ]
    },
    {
      "id": "northern_fragmentation",
      "name": "北方大崩解",
      "type": "outcome",
      "trigger": {
        "condition": "turn_number >= 8",
        "priority": "medium"
      },
      "title": "前秦崩溃 —— 十六国乱世再临",
      "narrative": "淝水惨败后，前秦帝国如积木崩塌。姚苌在关中自立为大秦王（后秦），慕容冲围攻长安，乞伏国仁割据陇西，吕光远征西域不再东返。\n\n曾经统一北方的前秦，如今仅剩长安孤城和少许残兵。苻坚在绝望中出奔五将山，被姚苌擒杀。\n\n北方重新陷入十六国混战——这是东晋的机遇，还是新一轮动荡的开始？",
      "auto_effects": {
