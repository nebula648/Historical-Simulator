  "scripted_events": [
    {
      "id": "evt_cz_001",
      "name": "大顺军兵临城下",
      "type": "audience",
      "trigger": {
        "condition": "month == 3 AND turn_number <= 2",
        "priority": "mandatory"
      },
      "title": "京师告急——大顺军已破大同，兵锋直指居庸关",
      "narrative": "崇祯十七年三月，李自成的大顺军在攻陷大同、宣府后，已进抵居庸关。京城三大营名存实亡，守军不足万人且欠饷数月，士气低落。满朝文武惶惶不可终日。\n\n大学士范景文跪奏：'陛下，京城危在旦夕。臣以为当召天下勤王之师，尤以山海关吴三桂之关宁铁骑为最要。然若调吴三桂入卫，则山海关空虚，恐建虏趁虚而入。此乃两难之局也！'\n\n兵部尚书张缙彦进言：'或请陛下南幸留都南京。江南富庶，且有长江天险，足可凭借。'\n\n你的决断将决定大明的命运。"
    },
    {
      "id": "evt_cz_002",
      "name": "吴三桂的山海关之择",
      "type": "audience",
      "trigger": {
        "condition": "month >= 4 AND month <= 5",
        "priority": "mandatory"
      },
      "title": "山海关上的抉择——联虏平寇，还是坚守孤城？",
      "narrative": "吴三桂的关宁铁骑已抵达山海关，但北京已经失陷的消息传来（若北京已失守）。更糟糕的是，李自成已派降将唐通率军进攻山海关，并以吴三桂的父亲吴襄为人质，逼迫吴三桂投降大顺。\n\n吴三桂在山海关城头徘徊不决。他派出密使，一面与大顺军周旋，一面派副将杨珅出关前往清军大营……\n\n多尔衮的使者带来了条件：'若将军开关迎清军入关，大清许诺封将军为平西王，且绝不伤害汉人百姓。'\n\n作为大明天子，你得知了吴三桂的处境。你的决定是——"
    },
    {
      "id": "evt_cz_003",
      "name": "崇祯殉国与南明建立",
      "type": "outcome",
      "trigger": {
        "condition": "ming_empire.controls('beijing') == false AND ming_empire.controls('nanjing') == true",
        "priority": "follow_up"
      },
      "title": "南都定策——陪都南京的新朝廷",
      "narrative": "北京陷落的消息传到南京，留都群臣在史可法、马士英等人的主持下，商讨拥立新君。南京六部建制完整，江南赋税充足，大明国祚仍有一线延续之机。\n\n史可法提议册立潞王朱常淓，而马士英与江北四镇将领力挺福王朱由崧。朝堂上的这场立嗣之争，将决定南明弘光朝廷的未来格局。",
      "auto_effects": {
        "ming_empire": {
          "treasury": 12000,
          "prestige": -20,
          "stability": -10
        }
      },
      "territory_changes": [],
      "diplomacy_changes": []
    },
    {
      "id": "evt_cz_004",
      "name": "扬州十日的前夜",
      "type": "conditional",
      "trigger": {
        "condition": "qing_empire.controls('beijing') AND year >= 1645 AND ming_empire.controls('yang_zhou')",
        "priority": "mandatory"
      },
      "title": "扬州——江南门户告急",
      "narrative": "清军在多铎的率领下大举南下，兵锋直指扬州。史可法以督师身份坐镇扬州，但江北四镇各怀异心。扬州的命运，牵动着整个江南的安危。"
    },
    {
      "id": "evt_cz_005",
      "name": "张献忠的动向",
      "type": "conditional",
      "trigger": {
        "condition": "year == 1645 AND month >= 6 AND xi_regime.status == 'active'",
        "priority": "random"
      },
      "title": "大西王北望——张献忠的战略抉择",
      "narrative": "盘踞四川的张献忠面临抉择。北面的清军正逐步南下，东面的南明虽虚弱但仍据有江南。探马来报：'清军前锋已入汉中，或不久即南下入川。'\n\n张献忠召集义子们商议：'明朝气数将尽，然满洲人若入川，我辈亦无葬身之地。如今之计，是继续东出争霸，还是与南明联手抗清？'"
    },
    {
      "id": "evt_cz_006",
      "name": "郑氏水师的战略价值",
      "type": "audience",
      "trigger": {
        "condition": "year >= 1645 AND ming_empire.controls('fu_zhou')",
        "priority": "mandatory"
      },
      "title": "海上的希望——郑芝龙父子的水师",
      "narrative": "福建总兵郑芝龙拥兵自重，麾下福建水师拥有大小战船千余艘，是东南沿海最强大的海上力量。其子郑森（后赐名成功）少年英武，深得军心。\n\n郑芝龙遣使到行在：'朝廷若能授予臣闽浙沿海之贸易专权，臣可保证每年进贡白银二十万两，并为朝廷守护海疆。'\n\n朝中有人担忧郑芝龙会成尾大不掉之势，也有人说值此危亡之际，当以大局为重。"
    }
  ],
