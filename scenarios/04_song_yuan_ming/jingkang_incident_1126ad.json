  "scripted_events": [
    {
      "id": "jk_siege_of_kaifeng",
      "name": "金兵围汴京",
      "type": "audience",
      "trigger": {
        "condition": "turn_number <= 3",
        "priority": "mandatory"
      },
      "title": "东京被围——金兵已渡黄河，直逼汴京城下",
      "narrative": "靖康元年正月，完颜宗望的东路军已破相州、浚州，渡过黄河天险，进抵东京开封府城下。汴京城外火光冲天，金军铁骑在城外驰骋叫阵。\n\n尚书右丞李纲力主坚守：'汴京三重城防、内外禁军尚有八万，西军勤王之师已在途中。弃城则中原尽失！'\n\n而宰相白时中与李邦彦则主张割地求和：'金兵势大，不如暂割河北三镇以求和，保全宗庙社稷。'\n\n朝堂之上，主战与主和两派争执不下。你是战是和？",
      "choices": [
        {
          "id": "defend_kaifeng",
          "text": "任命李纲为亲征行营使，死守汴京，以待天下勤王",
          "effects": {
            "treasury": -30000,
            "manpower": -8000,
            "prestige": 20,
            "stability": 10
          },
          "narrative_result": "赵桓任命李纲为亲征行营使，总领汴京防务。李纲发动军民加固城防，以神臂弓、床子弩封锁城墙。金兵数度攻城均被击退。\n\n恰在此时，种师道、姚平仲率西军主力日夜兼程赶到汴京勤王。二十万勤王军云集城外，与城内守军形成内外夹击之势！完颜宗望见势不妙，退兵至孟阳扎营，遣使请和……"
        },
        {
          "id": "sue_for_peace",
          "text": "接受金国条件，割让河北三镇、赔款百万、以亲王为质",
          "effects": {
            "treasury": -200000,
            "prestige": -25,
            "stability": -10,
            "corruption": 5
          },
          "territory_changes": [
            {"region_id": "河北", "to_faction": "jin_empire", "reason": "割让河北三镇予金国"},
            {"region_id": "山西", "to_faction": "jin_empire", "reason": "割让河东予金国"}
          ],
          "narrative_result": "朝廷接受金国条件，遣康王赵构与少宰张邦昌入金营为质，割让太原、中山、河间三镇，赔款黄金五百万两、白银五千万两。金兵暂时退去，然而朝野上下皆以此为奇耻大辱。太学生陈东率数百名士子伏阙上书，要求罢免主和派、复用李纲……"
        },
        {
          "id": "flee_south",
          "text": "连夜南幸，迁都江宁府（南京），暂避金兵锋芒",
          "effects": {
            "treasury": -50000,
            "prestige": -30,
            "stability": -15,
            "corruption": 10
          },
          "territory_changes": [
            {"region_id": "河南", "to_faction": "jin_empire", "reason": "汴京弃守，金兵占据中原"}
          ],
          "narrative_result": "赵桓率宗室百官仓皇南奔，渡江至江宁府。金兵不战而得汴京，纵兵大掠，千年帝都毁于一旦。\n\n南渡之后，朝廷威信扫地，河北、中原各州县纷纷降金或自立。康王赵构在应天府（商丘）被拥立为大元帅，大宋的国祚悬于一线……"
        }
      ]
    },
    {
      "id": "jk_qin_wang_army",
      "name": "勤王之师的抉择",
