  "scripted_events": [
    {
      "id": "evt_sf_001",
      "name": "请旨撤藩",
      "type": "conditional",
      "trigger": {
        "condition": "turn_number == 1",
        "priority": "mandatory"
      },
      "title": "康熙下诏撤藩——三藩命运的分水岭",
      "narrative": "康熙帝在乾清宫召集议政王大臣会议，下诏撤除三藩。平西王吴三桂、靖南王耿精忠、平南王尚可喜均被告知——交出军权、迁回关外。这是康熙削藩的雷霆手段，也是三藩命运的分水岭。\n\n谋士方光琛进言：'王爷，清廷已露獠牙。若从命，则人为刀俎我为鱼肉；若抗旨，则天下震动或可一搏。'\n\n吴三桂沉吟良久，望向五华山下连绵的关宁铁骑营帐……",
      "choices": [
        {
          "id": "choice_accept",
          "text": "接受撤藩，交出兵权，率部迁回辽东",
          "effects": { "wu_sangui": { "stability": -30, "prestige": -50 }, "qing_empire": { "stability": 15 } },
          "narrative_result": "吴三桂黯然接受了撤藩诏令。关宁铁骑放下刀剑，五华山王府人去楼空。一世枭雄，终归于寂。但这真的是结局吗？"
        },
        {
          "id": "choice_revolt",
          "text": "拒绝撤藩！树起'天下都招讨兵马大元帅'大旗，正式举兵反清！",
          "effects": { "wu_sangui": { "prestige": 10, "stability": 5 }, "qing_empire": { "stability": -20 } },
          "narrative_result": "吴三桂掷诏于地，在昆明五华山树起反旗。'兴明讨虏，恢复汉室'——檄文传遍天下，三藩之乱正式爆发！康熙帝龙颜大怒，调集八旗主力南下平叛。",
          "diplomacy_changes": [
            { "a": "wu_sangui", "b": "qing_empire", "tension_delta": 20, "new_status": "war" }
          ]
        }
      ]
    },
    {
      "id": "evt_sf_002",
      "name": "祭拜明陵",
      "type": "conditional",
      "trigger": {
        "condition": "turn_number >= 2 AND global_flags.revolt_started == true",
        "priority": "optional"
      },
      "title": "祭拜永历帝陵——争取天下汉人民心",
      "narrative": "谋士方光琛建议吴三桂以'祭拜永历帝陵'为名，在昆明城外举行隆重的祭奠仪式，以争取天下汉人民心。这是政治姿态，也是军事动员——让天下人知道，平西王是为大明复仇而来。\n\n然而，公开祭拜意味着断绝与清廷的一切回旋余地。是高举'反清复明'大旗，还是暂且以'割据自保'为号？",
      "choices": [
        {
          "id": "choice_worship_public",
          "text": "举行盛大祭奠，昭告天下'反清复明'",
          "effects": { "wu_sangui": { "prestige": 20, "manpower": 15000 }, "qing_empire": { "stability": -10 } },
          "narrative_result": "吴三桂白衣素冠，在永历帝陵前伏地痛哭。'先帝在上，臣三桂今日举义，为大明复仇！'——消息传出，湖广遗民群起响应，义军蜂拥来投。"
        },
        {
          "id": "choice_worship_private",
          "text": "私下祭拜，不对外声张，保持'割据称王'的模糊立场",
          "effects": { "wu_sangui": { "prestige": 5, "stability": 10 } },
          "narrative_result": "吴三桂在深夜独自前往永历陵，焚香默祷。他深知'反清复明'之名太重，不如暂且以'割据自保'为号，静观天下变局。"
        }
      ]
    },
    {
      "id": "evt_sf_003",
      "name": "联络耿精忠、尚可喜",
      "type": "outcome",
      "trigger": {
        "condition": "turn_number >= 3 AND global_flags.revolt_started == true",
        "priority": "mandatory"
      },
      "title": "联络耿精忠、尚可喜——三藩合纵之势",
      "narrative": "反旗已举，当务之急是联络福建耿精忠与广东尚之信共同起兵。三藩若能合纵，则可形成西南-东南-岭南的铁三角，对清廷构成致命威胁。\n\n吴三桂遣密使分赴福州与广州。耿精忠在犹豫数日后举兵响应，自称'总统兵马大将军'。尚之信囚禁其父尚可喜，控制广州，响应吴三桂。三藩合纵之势初成，清廷朝野震惊！",
      "auto_effects": {
        "geng_jingzhong": { "stability": -10 },
        "shang_kexi": { "stability": -10 }
      },
      "diplomacy_changes": [
        { "a": "wu_sangui", "b": "geng_jingzhong", "tension_delta": -20, "new_status": "allied" },
        { "a": "wu_sangui", "b": "shang_kexi", "tension_delta": -15, "new_status": "allied" }
      ]
    },
    {
      "id": "evt_sf_004",
      "name": "清廷反击",
      "type": "outcome",
      "trigger": {
        "condition": "turn_number >= 5 AND global_flags.revolt_started == true",
        "priority": "mandatory"
      },
      "title": "康熙调兵遣将——大清帝国的全面反击",
      "narrative": "康熙帝在乾清宫昼夜不眠，亲自调度各路兵马。图海率禁旅八旗自京南下，张勇率西宁劲旅入川截击，蔡毓荣在长江布防。大清帝国的战争机器全速运转，一场席卷半个中国的内战全面升级！",
      "auto_effects": {
        "qing_empire": { "stability": 5, "manpower": 50000 },
        "wu_sangui": { "stability": -5 }
      }
    },
    {
      "id": "evt_sf_005",
      "name": "耿精忠动摇",
      "type": "conditional",
      "trigger": {
        "condition": "turn_number >= 8 AND global_flags.geng_joined == true",
        "priority": "optional"
      },
      "title": "耿精忠动摇——福建面临清军水陆夹攻",
      "narrative": "清廷重兵压境，耿精忠的福建孤悬东南沿海，难以抵挡清军水陆夹攻。密使传来消息：耿精忠正在与清廷暗中接触，有投降之意！若耿精忠降清，福建门户大开，吴三桂将失去重要的东南盟友。\n\n马宝请命：'末将愿率贵州劲旅入闽，助耿精忠稳定军心！'但方光琛警告：'贵州兵力抽调，则西南门户空虚，康熙必趁虚而入。'",
      "choices": [
        {
          "id": "choice_reinforce_geng",
          "text": "派马宝率军入闽，支援耿精忠稳定军心",
          "effects": { "wu_sangui": { "manpower": -8000, "prestige": 5 }, "geng_jingzhong": { "stability": 20 } },
          "narrative_result": "马宝率贵州劲旅昼夜兼程入闽，耿精忠闻讯大喜，军心暂稳。但这也意味着贵州防线出现空虚——康熙会抓住这个机会吗？"
        },
        {
          "id": "choice_abandon_geng",
          "text": "放弃耿精忠，集中兵力北进湖广",
          "effects": { "geng_jingzhong": { "stability": -40 }, "qing_empire": { "stability": 10 } },
          "narrative_result": "吴三桂选择放弃福建。耿精忠孤立无援，不久后降清。福建落入清廷之手，但吴三桂的主力得以完整地投入湖广战场。取舍之间，皆是豪赌。",
          "diplomacy_changes": [
            { "a": "wu_sangui", "b": "geng_jingzhong", "tension_delta": 50, "new_status": "neutral" },
