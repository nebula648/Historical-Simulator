  "factions": {
    "wu_sangui": {
      "name": "平西王·吴三桂",
      "color": "#8B0000",
      "ruler": "吴三桂",
      "ruler_title": "天下都招讨兵马大元帅·平西王",
      "government": "藩王割据政权",
      "capital": "云南",
      "description": "吴三桂，引清兵入关又亲手绞杀永历帝的前明叛将，如今坐镇云南、贵州两省，节制云贵川湖广五省兵马，拥兵二十万，富可敌国。康熙帝欲撤三藩，吴三桂骑虎难下——降则削藩夺权、人为刀俎；叛则天下震动、或可一搏。关宁铁骑尚在，大明遗民犹存，这一次，他要为自己而战。",
      "flag_badass": true,
      "faction_type": "Rebellion"
